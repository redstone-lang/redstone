{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Redstone",
  "scopeName": "source.red",
  "fileTypes": ["red"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#numbers" },
    { "include": "#strings" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "match": "//.*$",
      "name": "comment.line.double-slash.red"
    },
    "keywords": {
      "match": "\\b(fn|let|return|while|true|false|print)\\b",
      "name": "keyword.control.red"
    },
    "types": {
      "match": "\\b(i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|f32|f64|bool|char)\\b",
      "name": "storage.type.red"
    },
    "functions": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "name": "entity.name.function.red"
    },
    "numbers": {
      "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b",
      "name": "constant.numeric.red"
    },
    "strings": {
      "match": "'[^'\\\\]'",
      "name": "string.quoted.single.red"
    },
    "operators": {
      "match": "(->|\\+=|-=|\\*=|/=|<=|>=|==|!=|[+\\-*/<>=])",
      "name": "keyword.operator.red"
    }
  }
}
